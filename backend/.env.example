# =====================================================================
# Mister Fantasy API credentials
# ---------------------------------------------------------------------
# Log into https://mister.mundodeportivo.com/, open DevTools (F12) ->
# Network tab, click any request and copy these values from its headers.
# =====================================================================

MISTER_AUTH_TOKEN="your_x_auth_token_here"
MISTER_LEAGUE_ID="your_league_id_here"
MISTER_COOKIE="your_cookie_header_here"

# =====================================================================
# AI providers
# ---------------------------------------------------------------------
# Primary: local Ollama (free & private). Pull the model first:
#   ollama pull qwen3.5:9b
# Fallback: Google Gemini (used automatically when Ollama is offline).
# =====================================================================

OLLAMA_MODEL="qwen3.5:9b"
# OLLAMA_BASE_URL="http://localhost:11434"

# Optional: Gemini cloud fallback
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
